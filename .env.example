# ============================================
# Lead Outreach System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=leadoutreach
POSTGRES_PASSWORD=leadoutreach_secret
POSTGRES_DB=leadoutreach
# Connection URL used by the backend (points to the Docker service name "postgres")
DATABASE_URL=postgresql+asyncpg://leadoutreach:leadoutreach_secret@postgres:5432/leadoutreach

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT Authentication ---
# Generate a strong random secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption (for storing API keys in the database) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_TO_A_FERNET_KEY

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
